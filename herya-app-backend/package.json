{
	"name": "herya-app-backend",
	"version": "1.0.0",
	"description": "Yoga app backend built with Node.js, Express, and MongoDB. Provides RESTful APIs for managing yoga poses, breathing patterns, sequences, and user data.",
	"main": "index.js",
	"scripts": {
		"start": "node index.js",
		"dev": "nodemon index.js",
		"seed": "node ./src/seeds/index.js",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"check": "biome check .",
		"check:fix": "biome check --write --unsafe .",
		"test": "jest --runInBand"
	},
	"keywords": [
		"yoga",
		"backend",
		"nodejs",
		"express",
		"mongodb",
		"api"
	],
	"author": "Max Primavera",
	"license": "ISC",
	"type": "commonjs",
	"dependencies": {
		"bcrypt": "^6.0.0",
		"cloudinary": "^1.41.3",
		"cors": "^2.8.6",
		"dotenv": "^17.3.1",
		"express": "^5.2.1",
		"express-validator": "^7.3.1",
		"jsonwebtoken": "^9.0.3",
		"mongoose": "^9.2.1",
		"morgan": "^1.10.1",
		"multer": "^2.0.2",
		"multer-storage-cloudinary": "^4.0.0",
		"papaparse": "^5.5.3",
		"swagger-jsdoc": "^6.2.8",
		"swagger-ui-express": "^5.0.1"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.0",
		"jest": "^30.2.0",
		"mongodb-memory-server": "^11.0.1",
		"nodemon": "^3.1.11",
		"supertest": "^7.2.2"
	}
}
