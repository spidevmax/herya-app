# Environment Configuration
# Copy this file to .env and fill in your values
# cp .env.example .env

# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database ─────────────────────────────────────────────────────────────────
# MongoDB connection string (Atlas or local)
# Example: mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>
DB_URL=

# ─── Frontend (CORS) ──────────────────────────────────────────────────────────
# URL of the frontend app (used to configure CORS)
# Development: http://localhost:5173
# Production: https://your-frontend-domain.com
FRONTEND_URL=http://localhost:5173

# ─── Cloudinary (Image / Audio Storage) ──────────────────────────────────────
# Get these from https://console.cloudinary.com
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── JWT Authentication ───────────────────────────────────────────────────────
# Use a long random string in production (e.g. openssl rand -base64 64)
JWT_SECRET=

# ─── SMTP (Password Reset Emails) ─────────────────────────────────────────────
# Required in production to send real password reset emails.
# Example with Mailtrap / SendGrid SMTP relay:
# SMTP_HOST=sandbox.smtp.mailtrap.io
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=<smtp-user>
# SMTP_PASS=<smtp-password>
# SMTP_FROM=Herya <no-reply@herya.app>
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
