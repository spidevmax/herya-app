{
	"$schema": "https://biomejs.dev/schemas/2.4.0/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": true
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"correctness": {
				"noUnusedFunctionParameters": "info"
			},
			"style": {
				"useNodejsImportProtocol": "warn"
			}
		}
	},
	"javascript": {
		"globals": [
			"process",
			"__dirname",
			"__filename",
			"require",
			"module",
			"exports",
			"Buffer",
			"setTimeout",
			"setInterval",
			"clearTimeout",
			"clearInterval",
			"console"
		],
		"formatter": {
			"quoteStyle": "double",
			"trailingCommas": "all",
			"semicolons": "always",
			"arrowParentheses": "always"
		},
		"parser": {
			"unsafeParameterDecoratorsEnabled": false
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"overrides": [
		{
			"includes": ["src/seeds/**"],
			"linter": {
				"rules": {
					"correctness": {
						"noUnusedFunctionParameters": "off"
					}
				}
			}
		}
	]
}
